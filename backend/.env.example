# ==============================================================================
# 大语言模型配置 (LLM Config)
# ==============================================================================

# 选择你要使用的 LLM 提供商 (openai, google, anthropic, ollama, deepseek, qwen 等)
TRADINGAGENTS_LLM_PROVIDER=google

# 深度思考模型 (主分析、辩论、风控、PM 决策)
TRADINGAGENTS_DEEP_THINK_LLM=gemini-1.5-pro

# 快速思考模型 (一些轻量级的文本格式化、摘要)
TRADINGAGENTS_QUICK_THINK_LLM=gemini-1.5-flash

# 如果选择的是 google/gemini，请配置您的 Google 开发者 Key
GOOGLE_API_KEY=your_gemini_api_key_here

# 如果选择的是 openai/deepseek 等兼容 OpenAI 接口的模型，配置如下：
# TRADINGAGENTS_LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
#
# 或者使用自定义 OpenAI 兼容网关：
# TRADINGAGENTS_LLM_PROVIDER=openai
# OPENAI_API_KEY=your_custom_key_here
# TRADINGAGENTS_LLM_BACKEND_URL=https://api.deepseek.com/v1

# ==============================================================================
# 金融数据提供商配置 (Financial Data Providers Config)
# ==============================================================================

# 默认使用 yfinance (免 Key)，支持免费测试
# 若要使用其它提供商，在下方取消注释并填写相应的 Key 即可：
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# POLYGON_API_KEY=your_polygon_key_here
# FMP_API_KEY=your_fmp_key_here

# ==============================================================================
# 其它系统设置
# ==============================================================================
TRADINGAGENTS_OUTPUT_LANGUAGE=Chinese
TRADINGAGENTS_RESULTS_DIR=../frontend/docs/reports
TRADINGAGENTS_CACHE_DIR=./cache
TRADINGAGENTS_MEMORY_LOG_PATH=./memory/trading_memory.md
